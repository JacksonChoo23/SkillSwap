<% const s=session || {}; const fmt=value=> value ? new Date(value).toLocaleString('en-MY', { dateStyle: 'medium',
  timeStyle: 'short' }) : '-';
  const isTeacher = user && s.teacherId === user.id;
  const isLearner = user && s.studentId === user.id;
  const myRole = isTeacher ? 'Teacher' : isLearner ? 'Learner' : 'Viewer';
  const partnerRole = isTeacher ? 'Learner' : 'Teacher';
  const partner = isTeacher ? s.student : s.teacher;

  const statusSteps = ['requested', 'confirmed', 'in_progress', 'completed'];
  const currentStepIndex = statusSteps.indexOf(s.status);
  const isCancelled = s.status === 'cancelled';

  const statusConfig = {
  requested: { icon: 'fa-clock', color: 'warning', label: 'Requested' },
  confirmed: { icon: 'fa-check-circle', color: 'primary', label: 'Confirmed' },
  in_progress: { icon: 'fa-play-circle', color: 'info', label: 'In Progress' },
  completed: { icon: 'fa-trophy', color: 'success', label: 'Completed' },
  cancelled: { icon: 'fa-ban', color: 'secondary', label: 'Cancelled' }
  };
  const currentStatus = statusConfig[s.status] || statusConfig.requested;
  %>

  <!-- Hero Header -->
  <div class="card border-0 shadow-sm mb-4 overflow-hidden">
    <div class="card-body p-0">
      <!-- Status Banner -->
      <div id="status-banner"
        class="bg-<%= currentStatus.color %> <%= s.status === 'in_progress' ? 'text-dark' : 'text-white' %> px-4 py-3"
        data-status="<%= s.status %>">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
          <div>
            <div class="d-flex align-items-center gap-2 mb-1">
              <i class="fas <%= currentStatus.icon %> fa-lg"></i>
              <span class="fw-bold fs-5 text-uppercase">
                <%= currentStatus.label %>
              </span>
            </div>
            <small class="opacity-75">Session ID: #<%= s.id %></small>
          </div>
          <% if (isTeacher || isLearner) { %>
            <div class="d-flex align-items-center gap-2 bg-white bg-opacity-25 rounded-pill px-3 py-2">
              <i class="fas <%= isTeacher ? 'fa-chalkboard-teacher' : 'fa-user-graduate' %>"></i>
              <span class="fw-semibold">You are the <%= myRole %></span>
            </div>
            <% } %>
        </div>
      </div>

      <!-- Main Info -->
      <div class="p-4">
        <div class="d-flex align-items-start justify-content-between mb-3">
          <a class="btn btn-sm btn-outline-secondary" href="javascript:history.back()">
            <i class="fas fa-arrow-left me-1"></i>Back
          </a>
        </div>

        <h1 class="h3 fw-bold mb-2">
          <i class="fas fa-book-open text-primary me-2"></i>
          <%= s.Skill?.name || 'Skill Session' %>
        </h1>

        <div class="row g-3 mt-3">
          <div class="col-6 col-md-3">
            <div class="bg-light rounded-3 p-3 text-center h-100">
              <i class="fas fa-chalkboard-teacher text-success mb-2 fa-lg"></i>
              <div class="small text-muted">Teacher</div>
              <div class="fw-semibold">
                <%= s.teacher?.name || 'Pending' %>
              </div>
              <% if (isTeacher) { %><span class="badge bg-success-subtle text-success border border-success border-opacity-10 mt-1">You</span>
                <% } %>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="bg-light rounded-3 p-3 text-center h-100">
              <i class="fas fa-user-graduate text-primary mb-2 fa-lg"></i>
              <div class="small text-muted">Learner</div>
              <div class="fw-semibold">
                <%= s.student?.name || 'Pending' %>
              </div>
              <% if (isLearner) { %><span class="badge bg-primary-subtle text-primary border border-primary border-opacity-10 mt-1">You</span>
                <% } %>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="bg-light rounded-3 p-3 text-center h-100">
              <i class="fas fa-calendar text-info mb-2 fa-lg"></i>
              <div class="small text-muted">Scheduled</div>
              <div class="fw-semibold small">
                <%= fmt(s.startAt) %>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="bg-light rounded-3 p-3 text-center h-100">
              <i class="fas fa-hourglass-end text-warning mb-2 fa-lg"></i>
              <div class="small text-muted">Until</div>
              <div class="fw-semibold small">
                <%= fmt(s.endAt) %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Status Progress Stepper (not shown if cancelled) -->
  <% if (!isCancelled) { %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <h2 class="h6 text-uppercase text-muted mb-3"><i class="fas fa-route me-2"></i>Session Progress</h2>
        <div class="d-flex justify-content-between position-relative">
          <!-- Progress Line -->
          <div class="position-absolute"
            style="top: 20px; left: 12%; right: 12%; height: 4px; background: #e9ecef; z-index: 0;">
            <div class="h-100 bg-success"
              style="width: <%= Math.max(0, (currentStepIndex / (statusSteps.length - 1)) * 100) %>%; transition: width 0.5s;">
            </div>
          </div>

          <% statusSteps.forEach((step, idx)=> {
            const isPast = idx < currentStepIndex; const isCurrent=idx===currentStepIndex; const cfg=statusConfig[step];
              %>
              <div class="text-center position-relative" style="z-index: 1; width: 25%;">
                <div
                  class="rounded-circle d-inline-flex align-items-center justify-content-center mb-2 
          <%= isPast || isCurrent ? 'bg-' + cfg.color + (step === 'in_progress' ? ' text-dark' : ' text-white') : 'bg-light text-muted' %>"
                  style="width: 40px; height: 40px;">
                  <i class="fas <%= cfg.icon %>"></i>
                </div>
                <div
                  class="small <%= isCurrent ? 'fw-bold text-' + cfg.color : isPast ? 'text-success' : 'text-muted' %>">
                  <%= cfg.label %>
                </div>
              </div>
              <% }) %>
        </div>
      </div>
    </div>
    <% } %>

      <div class="row g-4">
        <!-- Main Content Column -->
        <div class="col-lg-8">

          <!-- Action Card - Most Important -->
          <div class="card border-0 shadow-sm mb-4 border-start border-4 border-primary">
            <div class="card-header bg-white border-0 pb-0">
              <h2 class="h6 text-uppercase text-primary mb-0">
                <i class="fas fa-bolt me-2"></i>Your Actions
              </h2>
            </div>
            <div class="card-body" id="action-card-body">
              <% if (s.status==='cancelled' ) { %>
                <div class="alert alert-secondary mb-0">
                  <i class="fas fa-ban me-2"></i>This session has been cancelled. No actions available.
                </div>
                <% } else if (s.status==='completed' ) { %>
                  <div class="alert alert-success mb-0">
                    <i class="fas fa-check-circle me-2"></i>Session completed! Please rate your experience below.
                  </div>
                  <% } else { %>

                    <!-- Teacher: Requested → Confirm -->
                    <% if (s.status==='requested' && isTeacher) { %>
                      <div class="d-grid gap-2">
                        <form method="POST" action="/sessions/<%= s.id %>/confirm">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-check-circle me-2"></i>Accept Session Request
                          </button>
                        </form>
                        <p class="text-muted text-center small mb-0">
                          <i class="fas fa-info-circle me-1"></i>Accept to confirm this teaching appointment
                        </p>
                      </div>
                      <% } %>

                        <!-- Learner: Requested → Wait -->
                        <% if (s.status==='requested' && isLearner) { %>
                          <div class="alert alert-warning mb-0">
                            <i class="fas fa-clock me-2"></i>
                            <strong>Waiting for teacher confirmation.</strong><br>
                            <small>
                              <%= s.teacher?.name || 'The teacher' %> will confirm or decline your request.
                            </small>
                          </div>
                          <% } %>

                            <!-- Teacher: Confirmed → Generate Code -->
                            <% if (s.status==='confirmed' && isTeacher) { %>
                              <div class="d-grid gap-3">
                                <form method="POST" action="/sessions/<%= s.id %>/generate-code">
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                  <button class="btn btn-primary btn-lg w-100">
                                    <i class="fas fa-key me-2"></i>Generate Start Code
                                  </button>
                                </form>
                                <% if (s.startCode) { %>
                                  <div class="alert alert-info mb-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                      <div>
                                        <small class="text-muted d-block">Current Code</small>
                                        <span class="fs-3 fw-bold font-monospace">
                                          <%= s.startCode %>
                                        </span>
                                      </div>
                                      <div class="text-end">
                                        <small class="text-muted d-block">Expires</small>
                                        <span>
                                          <%= fmt(s.codeExpiresAt) %>
                                        </span>
                                      </div>
                                    </div>
                                    <hr>
                                    <small><i class="fas fa-share-alt me-1"></i>Share this code with your learner to
                                      start the session</small>
                                  </div>
                                  <% } else { %>
                                    <p class="text-muted text-center small mb-0">
                                      <i class="fas fa-info-circle me-1"></i>Generate a code and share it with your
                                      learner when you're ready to start
                                    </p>
                                    <% } %>
                              </div>
                              <% } %>

                                <!-- Learner: Confirmed → Enter Code -->
                                <% if (s.status==='confirmed' && isLearner) { %>
                                  <form method="POST" action="/sessions/<%= s.id %>/verify-code">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <div class="alert alert-info mb-3">
                                      <i class="fas fa-key me-2"></i>
                                      <strong>Ready to start!</strong> Ask your teacher for the start code.
                                    </div>
                                    <div class="input-group input-group-lg">
                                      <span class="input-group-text bg-light"><i class="fas fa-key"></i></span>
                                      <input name="code" class="form-control text-center fw-bold fs-4 font-monospace"
                                        placeholder="Enter code" pattern="\d{3,6}" required maxlength="6">
                                      <button class="btn btn-success px-4" type="submit">
                                        <i class="fas fa-play me-1"></i>Start
                                      </button>
                                    </div>
                                  </form>
                                  <% } %>

                                    <!-- Teacher: In Progress → End Session -->
                                    <% if (s.status==='in_progress' && isTeacher) { %>
                                      <div class="d-grid gap-3">
                                        <form method="POST" action="/sessions/<%= s.id %>/end">
                                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                          <button class="btn btn-success btn-lg w-100">
                                            <i class="fas fa-flag-checkered me-2"></i>End Session
                                          </button>
                                        </form>
                                        <p class="text-muted text-center small mb-0">
                                          <i class="fas fa-info-circle me-1"></i>This will complete the session and
                                          award points to both participants
                                        </p>
                                      </div>
                                      <% } %>

                                        <!-- Learner: In Progress → Waiting -->
                                        <% if (s.status==='in_progress' && isLearner) { %>
                                          <div class="alert alert-info mb-0">
                                            <i class="fas fa-play-circle me-2"></i>
                                            <strong>Session in progress!</strong><br>
                                            <small>The teacher will end the session when complete.</small>
                                          </div>
                                          <% } %>

                                            <!-- Cancel Button (for all non-completed) -->
                                            <% if (s.status !=='completed' && (isTeacher || isLearner)) { %>
                                              <hr class="my-4">
                                              <form method="POST" action="/sessions/<%= s.id %>/cancel"
                                                class="text-center">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button class="btn btn-outline-danger">
                                                  <i class="fas fa-times me-1"></i>Cancel Session
                                                </button>
                                              </form>
                                              <% } %>

                                                <% } %>
            </div>
          </div>

          <!-- Live Timer (In Progress) -->
          <div id="timer-container" class="<%= s.status==='in_progress' && s.actualStartAt ? '' : 'd-none' %>">
            <% if (s.status==='in_progress' && s.actualStartAt) { %>
              <div class="card border-0 shadow-sm mb-4 bg-info bg-opacity-10">
                <div class="card-body text-center py-4">
                  <i class="fas fa-stopwatch fa-2x text-info mb-2"></i>
                  <p class="text-uppercase text-muted small mb-1">Session Duration</p>
                  <div class="display-4 fw-bold text-info" id="stopwatch">00:00:00</div>
                  <p class="text-muted small mb-0">Session started at <%= fmt(s.actualStartAt) %>
                  </p>
                </div>
              </div>
              <script>
                (function timer() {
                  const startTimestamp = Date.parse('<%= new Date(s.actualStartAt).toISOString() %>');
                  const el = document.getElementById('stopwatch');
                  if (!el) return;
                  const pad = val => String(val).padStart(2, '0');
                  function tick() {
                    const diff = Math.max(0, Date.now() - startTimestamp);
                    const hrs = Math.floor(diff / 3600000);
                    const mins = Math.floor((diff % 3600000) / 60000);
                    const secs = Math.floor((diff % 60000) / 1000);
                    el.textContent = `${pad(hrs)}:${pad(mins)}:${pad(secs)}`;
                  }
                  tick();
                  setInterval(tick, 1000);
                })();
              </script>
              <% } %>
          </div>

          <!-- Ratings Section -->
          <div class="card border-0 shadow-sm" id="ratings-section">
            <div class="card-header bg-white border-0 pb-0 d-flex justify-content-between align-items-center"
              id="ratings-header">
              <h2 class="h6 text-uppercase text-muted mb-0">
                <i class="fas fa-star me-2"></i>Ratings & Feedback
              </h2>
              <% if (s.status==='completed' ) { %>
                <span class="badge bg-warning-subtle text-warning border border-warning border-opacity-10 py-1"><i class="fas fa-star me-1"></i>Feedback Time!</span>
                <% } %>
            </div>
            <div class="card-body" id="ratings-body">
              <% const userRating=s.ratings && s.ratings.find(r=> r.raterId === user.id); %>

                <% if (s.status==='completed' && (isTeacher || isLearner)) { %>
                  <% if (!userRating) { %>
                    <form method="POST" action="/ratings/<%= s.id %>" class="mb-4">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="hidden" name="rateeId" value="<%= isTeacher ? s.studentId : s.teacherId %>">

                      <div class="alert alert-warning mb-3">
                        <i class="fas fa-star me-2"></i>
                        <strong>Rate your <%= isTeacher ? 'learner' : 'teacher' %>!</strong>
                        Your feedback helps improve the community.
                      </div>

                      <div class="row g-3 mb-3">
                        <% ['communication', 'skill' , 'attitude' , 'punctuality' ].forEach(field=> { %>
                          <div class="col-6 col-md-3">
                            <label class="form-label small text-muted text-capitalize">
                              <%= field %>
                            </label>
                            <select class="form-select" name="<%= field %>" required>
                              <option value="">-</option>
                              <% [5,4,3,2,1].forEach(score=> { %>
                                <option value="<%= score %>">
                                  <%= '★' .repeat(score) %>
                                </option>
                                <% }) %>
                            </select>
                          </div>
                          <% }) %>
                      </div>

                      <div class="mb-3">
                        <label class="form-label small text-muted">Comment (optional)</label>
                        <textarea class="form-control" name="comment" rows="2" maxlength="500"
                          placeholder="Share your experience..."></textarea>
                      </div>

                      <button class="btn btn-primary">
                        <i class="fas fa-paper-plane me-1"></i>Submit Rating
                      </button>
                    </form>
                    <% } else { %>
                      <div class="alert alert-success mb-4">
                        <i class="fas fa-check-circle me-2"></i>You have already rated this session. Thank you!
                      </div>
                      <% } %>
                        <% } %>

                          <!-- Existing Ratings -->
                          <% if (!Array.isArray(s.ratings) || !s.ratings.length) { %>
                            <p class="text-muted small mb-0"><i class="fas fa-info-circle me-1"></i>No ratings yet.
                            </p>
                            <% } else { %>
                              <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                  <thead class="table-light">
                                    <tr class="small text-muted">
                                      <th>From</th>
                                      <th>To</th>
                                      <th class="text-center">Avg</th>
                                      <th>Comment</th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% s.ratings.forEach(r=> {
                                      const avg = ((r.communication + r.skill + r.attitude + r.punctuality) /
                                      4).toFixed(1);
                                      %>
                                      <tr>
                                        <td>
                                          <%= r.rater?.name || '-' %>
                                        </td>
                                        <td>
                                          <%= r.ratee?.name || '-' %>
                                        </td>
                                        <td class="text-center">
                                          <span class="badge bg-warning-subtle text-warning border border-warning border-opacity-10 py-1">
                                            <%= avg %> ★
                                          </span>
                                        </td>
                                        <td>
                                          <%= r.comment || '-' %>
                                        </td>
                                      </tr>
                                      <% }) %>
                                  </tbody>
                                </table>
                              </div>
                              <% } %>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
          <!-- Quick Contact -->
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pb-0">
              <h2 class="h6 text-uppercase text-muted mb-0">
                <i class="fas fa-address-book me-2"></i>Contact <%= partnerRole %>
              </h2>
            </div>
            <div class="card-body">
              <% if (isTeacher || isLearner) { %>
                <div class="d-flex align-items-center gap-3 mb-3">
                  <div class="bg-light rounded-circle d-flex align-items-center justify-content-center"
                    style="width: 50px; height: 50px;">
                    <i class="fas fa-user fa-lg text-muted"></i>
                  </div>
                  <div>
                    <div class="fw-semibold">
                      <%= partner?.name || 'Unknown' %>
                    </div>
                    <small class="text-muted">
                      <%= partnerRole %>
                    </small>
                  </div>
                </div>
                <div class="d-grid gap-2">
                  <% if (partner?.whatsapp_number) { %>
                    <a class="btn btn-success btn-sm" target="_blank" rel="noopener"
                      href="https://wa.me/<%= partner.whatsapp_number %>">
                      <i class="fab fa-whatsapp me-1"></i>WhatsApp
                    </a>
                    <% } else if (partner?.email) { %>
                      <% const skillName=s.Skill?.name || 'our session' ; const
                        sessionEmailSubject=encodeURIComponent(`SkillSwap MY - About our ${skillName} session`); const
                        sessionEmailBody=encodeURIComponent( `Hi ${partner.name},\n\n` + `I'm reaching out regarding our
                        ${skillName} session on SkillSwap MY.\n\n` + `Session Details:\n` + `- Skill: ${skillName}\n` +
                        `- Scheduled: ${new Date(s.startAt).toLocaleString('en-MY', { dateStyle: 'medium' ,
                        timeStyle: 'short' })}\n\n` + `Please let me know if you have any questions or need to discuss
                        anything.\n\n` + `Best regards,\n${user.name || 'Your SkillSwap partner' }` ); %>
                        <a class="btn btn-primary btn-sm"
                          href="mailto:<%= partner.email %>?subject=<%= sessionEmailSubject %>&body=<%= sessionEmailBody %>">
                          <i class="fas fa-envelope me-1"></i>Email
                        </a>
                        <% } else { %>
                          <button class="btn btn-outline-secondary btn-sm" disabled>
                            <i class="fas fa-user-slash me-1"></i>No contact info
                          </button>
                          <% } %>
                </div>
                <% } else { %>
                  <p class="text-muted small mb-0">Contact info visible to participants only.</p>
                  <% } %>
            </div>
          </div>

          <!-- Tips & Reports -->
          <% if (isTeacher || isLearner) { %>
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-header bg-white border-0 pb-0">
                <h2 class="h6 text-uppercase text-muted mb-0">
                  <i class="fas fa-gift me-2"></i>Tips & Reports
                </h2>
              </div>
              <div class="card-body">
                <% const otherUserId=isTeacher ? s.studentId : s.teacherId; %>
                  <div class="d-grid gap-2">
                    <button class="btn btn-outline-warning btn-sm js-tip" data-user-id="<%= otherUserId %>"
                      data-user-name="<%= partner?.name %>">
                      <i class="fas fa-coins me-1"></i>Send Tip
                    </button>
                    <button class="btn btn-outline-danger btn-sm js-report" data-target-id="<%= otherUserId %>"
                      data-target-name="<%= partner?.name %>" data-session-id="<%= s.id %>">
                      <i class="fas fa-flag me-1"></i>Report Issue
                    </button>
                    <a class="btn btn-outline-secondary btn-sm" href="/tips">
                      <i class="fas fa-wallet me-1"></i>My Tips
                    </a>
                  </div>
              </div>
            </div>
            <% } %>

              <!-- Session Times (Actual) -->
              <% if (s.actualStartAt || s.actualEndAt) { %>
                <div class="card border-0 shadow-sm">
                  <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h6 text-uppercase text-muted mb-0">
                      <i class="fas fa-history me-2"></i>Actual Times
                    </h2>
                  </div>
                  <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                      <span class="text-muted">Started</span>
                      <span class="fw-semibold">
                        <%= fmt(s.actualStartAt) %>
                      </span>
                    </div>
                    <% if (s.actualEndAt) { %>
                      <div class="d-flex justify-content-between">
                        <span class="text-muted">Ended</span>
                        <span class="fw-semibold">
                          <%= fmt(s.actualEndAt) %>
                        </span>
                      </div>
                      <% } %>
                  </div>
                </div>
                <% } %>
        </div>
      </div>

      <!-- Real-time Session Status Updates -->
      <% if (user && (isTeacher || isLearner)) { %>
        <script src="/socket.io/socket.io.js"></script>
        <script>
          (function () {
            try {
              console.log('Session detail script loaded');
              // Session state tracking
              const sessionId = '<%= s.id %>';
              const userId = '<%= user.id %>';
              const isTeacher = <%= isTeacher ? 'true' : 'false' %>;
              const partnerName = '<%= partner?.name || "your partner" %>';
              const csrfToken = '<%= csrfToken %>';
              const rateeId = '<%= isTeacher ? s.studentId : s.teacherId %>';

              console.log('Variables initialized:', { sessionId, userId, isTeacher });

              // Track if user has given feedback
              let hasGivenFeedback = <%= (s.ratings && s.ratings.some(r => r.raterId === user.id)) ? 'true' : 'false' %>;
              let sessionCompleted = <%= s.status === 'completed' ? 'true' : 'false' %>;

              console.log('State:', { hasGivenFeedback, sessionCompleted });

              // Block leaving page if session completed but no feedback given
              function updateBeforeUnload() {
                if (sessionCompleted && !hasGivenFeedback) {
                  window.onbeforeunload = function (e) {
                    const msg = 'Please provide feedback before leaving. Your rating helps improve the community!';
                    e.returnValue = msg;
                    return msg;
                  };
                } else {
                  window.onbeforeunload = null;
                }
              }
              updateBeforeUnload();

              // Intercept all link clicks with SweetAlert when feedback required
              function interceptNavigation() {
                if (!sessionCompleted || hasGivenFeedback) return;

                // Intercept link clicks
                document.addEventListener('click', function (e) {
                  if (!sessionCompleted || hasGivenFeedback) return;

                  const link = e.target.closest('a[href]');
                  if (link && !link.href.includes('/ratings/') && !link.href.includes('#')) {
                    e.preventDefault();
                    e.stopPropagation();

                    Swal.fire({
                      icon: 'warning',
                      title: 'Feedback Required',
                      html: '<p>Please provide your feedback before leaving this page.</p><p class="text-muted small">Your rating helps improve the community and is required to complete the session.</p>',
                      showCancelButton: true,
                      confirmButtonText: '<i class="fas fa-star"></i> Give Feedback Now',
                      cancelButtonText: 'Stay on Page',
                      confirmButtonColor: '#ffc107',
                      cancelButtonColor: '#6c757d',
                      allowOutsideClick: false,
                      allowEscapeKey: false
                    }).then((result) => {
                      if (result.isConfirmed) {
                        // Scroll to rating form
                        const ratingsSection = document.getElementById('ratings-section');
                        if (ratingsSection) {
                          ratingsSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                      }
                    });
                    return false;
                  }
                }, true);

                // Intercept browser back/forward button via popstate
                window.addEventListener('popstate', function (e) {
                  if (!sessionCompleted || hasGivenFeedback) return;

                  // Push state back to prevent navigation
                  history.pushState(null, '', window.location.href);

                  Swal.fire({
                    icon: 'warning',
                    title: 'Feedback Required',
                    html: '<p>Please provide your feedback before leaving this page.</p><p class="text-muted small">Your rating helps improve the community and is required to complete the session.</p>',
                    showCancelButton: false,
                    confirmButtonText: '<i class="fas fa-star"></i> Give Feedback Now',
                    confirmButtonColor: '#ffc107',
                    allowOutsideClick: false,
                    allowEscapeKey: false
                  }).then(() => {
                    // Scroll to rating form
                    const ratingsSection = document.getElementById('ratings-section');
                    if (ratingsSection) {
                      ratingsSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                  });
                });

                // Push initial state for popstate to work
                if (sessionCompleted && !hasGivenFeedback) {
                  history.pushState(null, '', window.location.href);
                }
              }
              interceptNavigation();

              // Function to update status banner
              function updateStatusBanner(status) {
                const banner = document.getElementById('status-banner');
                if (!banner) return;

                const config = {
                  in_progress: { icon: 'fa-play-circle', color: 'info', label: 'In Progress', textClass: 'text-dark' },
                  completed: { icon: 'fa-trophy', color: 'success', label: 'Completed', textClass: 'text-white' }
                };
                const cfg = config[status];
                if (!cfg) return;

                banner.className = `bg-${cfg.color} ${cfg.textClass} px-4 py-3`;
                banner.dataset.status = status;

                const iconEl = banner.querySelector('.fas');
                const labelEl = banner.querySelector('.fw-bold.fs-5');
                if (iconEl) iconEl.className = `fas ${cfg.icon} fa-lg`;
                if (labelEl) labelEl.textContent = cfg.label;
              }

              // Function to update action card for completed state
              function updateActionCard() {
                const actionBody = document.getElementById('action-card-body');
                if (!actionBody) return;

                actionBody.innerHTML = `
                <div class="alert alert-success mb-0">
                  <i class="fas fa-check-circle me-2"></i>Session completed! Please rate your experience below.
                </div>
              `;
              }

              // Function to hide timer
              function hideTimer() {
                const timerContainer = document.getElementById('timer-container');
                if (timerContainer) {
                  timerContainer.classList.add('d-none');
                }
              }

              // Function to show rating form dynamically
              function showRatingForm() {
                const ratingsBody = document.getElementById('ratings-body');
                const ratingsHeader = document.getElementById('ratings-header');
                if (!ratingsBody) return;

                // Add feedback badge to header if not present
                if (ratingsHeader && !ratingsHeader.querySelector('.badge')) {
                  const badge = document.createElement('span');
                  badge.className = 'badge bg-warning text-dark';
                  badge.innerHTML = '<i class="fas fa-star me-1"></i>Feedback Time!';
                  ratingsHeader.appendChild(badge);
                }

                // Check if form already exists
                if (ratingsBody.querySelector('form')) return;

                const partnerType = isTeacher ? 'learner' : 'teacher';
                const formHtml = `
                <form method="POST" action="/ratings/${sessionId}" class="mb-4" id="rating-form">
                  <input type="hidden" name="_csrf" value="${csrfToken}">
                  <input type="hidden" name="rateeId" value="${rateeId}">

                  <div class="alert alert-warning mb-3">
                    <i class="fas fa-star me-2"></i>
                    <strong>Rate your ${partnerType}!</strong>
                    Your feedback helps improve the community.
                  </div>

                  <div class="row g-3 mb-3">
                    ${['communication', 'skill', 'attitude', 'punctuality'].map(field => `
                      <div class="col-6 col-md-3">
                        <label class="form-label small text-muted text-capitalize">${field}</label>
                        <select class="form-select" name="${field}" required>
                          <option value="">-</option>
                          <option value="5">★★★★★</option>
                          <option value="4">★★★★</option>
                          <option value="3">★★★</option>
                          <option value="2">★★</option>
                          <option value="1">★</option>
                        </select>
                      </div>
                    `).join('')}
                  </div>

                  <div class="mb-3">
                    <label class="form-label small text-muted">Comment (optional)</label>
                    <textarea class="form-control" name="comment" rows="2" maxlength="500"
                      placeholder="Share your experience..."></textarea>
                  </div>

                  <button class="btn btn-primary" type="submit">
                    <i class="fas fa-paper-plane me-1"></i>Submit Rating
                  </button>
                </form>
              `;

                // Prepend form to ratings body
                ratingsBody.insertAdjacentHTML('afterbegin', formHtml);

                // Scroll to rating form
                document.getElementById('ratings-section')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }

              // Function to update progress stepper
              function updateStepper() {
                const stepperContainer = document.querySelector('.d-flex.justify-content-between.position-relative');
                if (!stepperContainer) return;

                // Update progress bar to 100%
                const progressBar = stepperContainer.querySelector('.h-100.bg-success');
                if (progressBar) {
                  progressBar.style.width = '100%';
                }

                // Update completed step
                const steps = stepperContainer.querySelectorAll('.text-center.position-relative');
                if (steps.length >= 4) {
                  const completedStep = steps[3];
                  const circle = completedStep.querySelector('.rounded-circle');
                  const label = completedStep.querySelector('.small');
                  if (circle) {
                    circle.className = 'rounded-circle d-inline-flex align-items-center justify-content-center mb-2 bg-success text-white';
                  }
                  if (label) {
                    label.className = 'small fw-bold text-success';
                  }
                }
              }

              // Handle session start - update UI dynamically (for teacher when learner starts)
              function handleSessionStarted() {
                // Update status banner to in_progress
                updateStatusBanner('in_progress');

                // Update stepper to show in_progress
                const stepperContainer = document.querySelector('.d-flex.justify-content-between.position-relative');
                if (stepperContainer) {
                  const progressBar = stepperContainer.querySelector('.h-100.bg-success');
                  if (progressBar) {
                    progressBar.style.width = '66%';
                  }
                  const steps = stepperContainer.querySelectorAll('.text-center.position-relative');
                  if (steps.length >= 3) {
                    const inProgressStep = steps[2];
                    const circle = inProgressStep.querySelector('.rounded-circle');
                    const label = inProgressStep.querySelector('.small');
                    if (circle) {
                      circle.className = 'rounded-circle d-inline-flex align-items-center justify-content-center mb-2 bg-info text-dark';
                    }
                    if (label) {
                      label.className = 'small fw-bold text-info';
                    }
                  }
                }

                // Update action card for teacher
                const actionBody = document.getElementById('action-card-body');
                if (actionBody && isTeacher) {
                  actionBody.innerHTML = `
                  <div class="d-grid gap-3">
                    <form method="POST" action="/sessions/${sessionId}/end">
                      <input type="hidden" name="_csrf" value="${csrfToken}">
                      <button class="btn btn-success btn-lg w-100">
                        <i class="fas fa-flag-checkered me-2"></i>End Session
                      </button>
                    </form>
                    <p class="text-muted text-center small mb-0">
                      <i class="fas fa-info-circle me-1"></i>This will complete the session and
                      award points to both participants
                    </p>
                  </div>
                  <hr class="my-4">
                  <form method="POST" action="/sessions/${sessionId}/cancel" class="text-center">
                    <input type="hidden" name="_csrf" value="${csrfToken}">
                    <button class="btn btn-outline-danger">
                      <i class="fas fa-times me-1"></i>Cancel Session
                    </button>
                  </form>
                `;
                } else if (actionBody && !isTeacher) {
                  actionBody.innerHTML = `
                  <div class="alert alert-info mb-0">
                    <i class="fas fa-play-circle me-2"></i>
                    <strong>Session in progress!</strong><br>
                    <small>The teacher will end the session when complete.</small>
                  </div>
                  <hr class="my-4">
                  <form method="POST" action="/sessions/${sessionId}/cancel" class="text-center">
                    <input type="hidden" name="_csrf" value="${csrfToken}">
                    <button class="btn btn-outline-danger">
                      <i class="fas fa-times me-1"></i>Cancel Session
                    </button>
                  </form>
                `;
                }

                // Show timer
                const timerContainer = document.getElementById('timer-container');
                if (timerContainer) {
                  timerContainer.classList.remove('d-none');
                  // Initialize timer if not already present
                  if (!timerContainer.querySelector('.card')) {
                    const startTime = new Date().toISOString();
                    timerContainer.innerHTML = `
                    <div class="card border-0 shadow-sm mb-4 bg-info bg-opacity-10">
                      <div class="card-body text-center py-4">
                        <i class="fas fa-stopwatch fa-2x text-info mb-2"></i>
                        <p class="text-uppercase text-muted small mb-1">Session Duration</p>
                        <div class="display-4 fw-bold text-info" id="stopwatch">00:00:00</div>
                        <p class="text-muted small mb-0">Session started just now</p>
                      </div>
                    </div>
                  `;
                    // Start timer
                    const startTimestamp = Date.now();
                    const el = document.getElementById('stopwatch');
                    const pad = val => String(val).padStart(2, '0');
                    setInterval(() => {
                      const diff = Math.max(0, Date.now() - startTimestamp);
                      const hrs = Math.floor(diff / 3600000);
                      const mins = Math.floor((diff % 3600000) / 60000);
                      const secs = Math.floor((diff % 60000) / 1000);
                      if (el) el.textContent = `${pad(hrs)}:${pad(mins)}:${pad(secs)}`;
                    }, 1000);
                  }
                }
              }

              // Handle session end - update UI dynamically
              function handleSessionCompleted() {
                sessionCompleted = true;
                updateBeforeUnload();
                interceptNavigation(); // Activate SweetAlert navigation blocker

                // Update UI components
                updateStatusBanner('completed');
                updateActionCard();
                hideTimer();
                updateStepper();

                // Show rating form if not already rated
                if (!hasGivenFeedback) {
                  showRatingForm();
                }
              }

              // Listen for form submission to update feedback state
              document.addEventListener('submit', function (e) {
                if (e.target.id === 'rating-form' || e.target.action?.includes('/ratings/')) {
                  hasGivenFeedback = true;
                  updateBeforeUnload();
                }
              });

              // Socket.io connection
              console.log('Checking for socket.io, io defined:', typeof io !== 'undefined');
              if (typeof io !== 'undefined') {
                const socket = io();

                // Function to join rooms
                function joinRooms() {
                  socket.emit('join_user', userId);
                  socket.emit('join_session', sessionId);
                  console.log('Socket: Joined user_' + userId + ' and session_' + sessionId);
                }

                // Handle room joining - check if already connected
                if (socket.connected) {
                  console.log('Socket already connected, joining rooms immediately');
                  joinRooms();
                } else {
                  socket.on('connect', () => {
                    console.log('Socket connected, joining rooms');
                    joinRooms();
                  });
                }

                // Listen for session started event - dynamic update, no refresh
                socket.on('session_started', (data) => {
                  console.log('Received session_started:', data);
                  if (String(data.sessionId) === String(sessionId)) {
                    if (typeof Swal !== 'undefined') {
                      Swal.fire({
                        icon: 'info',
                        title: 'Session Started!',
                        text: 'The session has been started. The timer is now running.',
                        showConfirmButton: true,
                        confirmButtonText: 'OK',
                        allowOutsideClick: false
                      }).then(() => {
                        handleSessionStarted();
                      });
                    } else {
                      handleSessionStarted();
                    }
                  }
                });

                // Listen for session completed - dynamic update, no refresh
                socket.on('session_completed', (data) => {
                  console.log('Received session_completed:', data);
                  if (String(data.sessionId) === String(sessionId)) {
                    if (typeof Swal !== 'undefined') {
                      Swal.fire({
                        icon: 'success',
                        title: 'Session Completed!',
                        text: `The session has been completed. Please provide your feedback.`,
                        showConfirmButton: true,
                        confirmButtonText: 'Rate Now',
                        allowOutsideClick: false,
                        allowEscapeKey: false
                      }).then(() => {
                        handleSessionCompleted();
                      });
                    } else {
                      handleSessionCompleted();
                    }
                  }
                });

                // Listen for session status changes
                socket.on('session_status_changed', (data) => {
                  console.log('Received session_status_changed:', data);
                  if (String(data.sessionId) === String(sessionId)) {
                    if (data.status === 'completed') {
                      if (typeof Swal !== 'undefined') {
                        Swal.fire({
                          icon: 'success',
                          title: 'Session Completed!',
                          text: data.message || 'Please provide your feedback.',
                          showConfirmButton: true,
                          confirmButtonText: 'Rate Now',
                          allowOutsideClick: false,
                          allowEscapeKey: false
                        }).then(() => {
                          handleSessionCompleted();
                        });
                      } else {
                        handleSessionCompleted();
                      }
                    } else if (data.status === 'in_progress') {
                      if (typeof Swal !== 'undefined') {
                        Swal.fire({
                          icon: 'info',
                          title: 'Session Started!',
                          text: data.message || 'The session is now in progress.',
                          showConfirmButton: true,
                          confirmButtonText: 'OK',
                          allowOutsideClick: false
                        }).then(() => {
                          handleSessionStarted();
                        });
                      } else {
                        handleSessionStarted();
                      }
                    }
                  }
                });
              }
            } catch (error) {
              console.error('Session detail script error:', error);
            }
          })();
        </script>
        <% } %>