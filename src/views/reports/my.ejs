<!-- src/views/reports/my.ejs -->
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0"><i class="bi bi-flag me-2"></i>My Reports</h2>
                <a href="/reports/new" class="btn btn-danger">
                    <i class="bi bi-plus-lg me-2"></i>New Report
                </a>
            </div>

            <% if (!reports || reports.length===0) { %>
                <div class="text-center py-5 bg-light rounded-4 border-2 border-dashed m-3">
                    <div class="mb-4">
                       <div class="bg-white rounded-circle shadow-sm d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                           <i class="fas fa-flag fa-2x text-muted opacity-25"></i>
                       </div>
                    </div>
                    <h6 class="text-dark fw-bold">No Reports Yet</h6>
                    <p class="text-muted small mb-0">You haven't submitted any reports.</p>
                </div>
                <% } else { %>
                    <div class="card border-0 shadow-sm">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Reported User</th>
                                        <th>Status</th>
                                        <th>AI Verdict</th>
                                        <th>Severity</th>
                                        <th>Date</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% reports.forEach(function(report) { %>
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <img src="<%= report.targetUser?.profileImage || '/images/default-avatar.png' %>"
                                                        alt="<%= report.targetUser?.name %>" class="rounded-circle me-2"
                                                        style="width: 40px; height: 40px; object-fit: cover;">
                                                    <span>
                                                        <%= report.targetUser?.name || 'Unknown' %>
                                                    </span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-<%= 
                        report.status === 'resolved' || report.status === 'auto_penalized' ? 'success' :
                        report.status === 'escalated' ? 'warning' :
                        report.status === 'dismissed' ? 'secondary' :
                        report.status === 'pending_ai' ? 'info' : 'primary'
                      %>-subtle text-<%= 
                        report.status === 'resolved' || report.status === 'auto_penalized' ? 'success' :
                        report.status === 'escalated' ? 'warning' :
                        report.status === 'dismissed' ? 'secondary' :
                        report.status === 'pending_ai' ? 'info' : 'primary'
                      %> border border-<%= 
                        report.status === 'resolved' || report.status === 'auto_penalized' ? 'success' :
                        report.status === 'escalated' ? 'warning' :
                        report.status === 'dismissed' ? 'secondary' :
                        report.status === 'pending_ai' ? 'info' : 'primary'
                      %> border-opacity-10 py-1">
                                                    <%= report.status.replace('_', ' ' ) %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-<%= 
                        report.aiVerdict === 'violation' ? 'danger' :
                        report.aiVerdict === 'harmless' ? 'success' :
                        report.aiVerdict === 'pending' ? 'secondary' : 'warning'
                      %>-subtle text-<%= 
                        report.aiVerdict === 'violation' ? 'danger' :
                        report.aiVerdict === 'harmless' ? 'success' :
                        report.aiVerdict === 'pending' ? 'secondary' : 'warning'
                      %> border border-<%= 
                        report.aiVerdict === 'violation' ? 'danger' :
                        report.aiVerdict === 'harmless' ? 'success' :
                        report.aiVerdict === 'pending' ? 'secondary' : 'warning'
                      %> border-opacity-10 py-1">
                                                    <%= report.aiVerdict %>
                                                </span>
                                            </td>
                                            <td>
                                                <% if (report.severity !=='none' ) { %>
                                                    <span class="badge bg-<%= 
                          report.severity === 'critical' ? 'danger' :
                          report.severity === 'high' ? 'warning' :
                          report.severity === 'medium' ? 'warning' : 'info'
                        %>-subtle text-<%= 
                          report.severity === 'critical' ? 'danger' :
                          report.severity === 'high' ? 'warning' :
                          report.severity === 'medium' ? 'warning' : 'info'
                        %> border border-<%= 
                          report.severity === 'critical' ? 'danger' :
                          report.severity === 'high' ? 'warning' :
                          report.severity === 'medium' ? 'warning' : 'info'
                        %> border-opacity-10 text-uppercase py-1">
                                                        <%= report.severity %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="text-muted">-</span>
                                                        <% } %>
                                            </td>
                                            <td>
                                                <small>
                                                    <%= new Date(report.createdAt).toLocaleDateString() %>
                                                </small>
                                            </td>
                                            <td>
                                                <a href="/reports/<%= report.id %>/review"
                                                    class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye me-1"></i>View
                                                </a>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <% } %>

                        <!-- Legend -->
                        <div class="card mt-4 border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-2"></i>Status Guide</h6>
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <span class="badge bg-info-subtle text-info border border-info border-opacity-10 py-1 me-2">pending ai</span>
                                        <small class="text-muted">Being analyzed</small>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="badge bg-primary-subtle text-primary border border-primary border-opacity-10 py-1 me-2">ai reviewed</span>
                                        <small class="text-muted">Awaiting your decision</small>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="badge bg-warning-subtle text-warning border border-warning border-opacity-10 py-1 me-2">escalated</span>
                                        <small class="text-muted">Sent to human review</small>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="badge bg-success-subtle text-success border border-success border-opacity-10 py-1 me-2">resolved</span>
                                        <small class="text-muted">Completed</small>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="badge bg-success-subtle text-success border border-success border-opacity-10 py-1 me-2">auto penalized</span>
                                        <small class="text-muted">Penalty applied</small>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary border-opacity-10 py-1 me-2">dismissed</span>
                                        <small class="text-muted">No action</small>
                                    </div>
                                </div>
                            </div>
                        </div>

        </div>
    </div>
</div>